TELEGRAM_BOT_TOKEN=123456:ABCDEF_your_token_here

# Ваша wiki
WIKI_BASE_URL=https://wiki.anycubic.com
WIKI_SITEMAP_URL=https://wiki.anycubic.com/sitemap.xml

# Лимит виртуальной памяти процесса в МиБ (только Linux/macOS, RLIMIT_AS). 0 = не ограничивать.
# При большом индексе 512 может быть мало — уменьшите WIKI_MAX_PAGES / INDEX_BATCH_SIZE или поднимите лимит.
MEMORY_LIMIT_MB=0

# Кэш индекса (чтобы не скачивать всё каждый запуск)
CACHE_PATH=.cache/wiki_index.json
# Файл состояния (прогресс постепенной индексации)
STATE_PATH=.cache/wiki_state.json
# Сколько часов кэш считается свежим
WIKI_REFRESH_HOURS=24
# Ограничение на количество страниц для индекса (0 = без лимита)
WIKI_MAX_PAGES=2000

# Минимальная “похожесть”, чтобы считать что ответ найден (0..100)
MIN_SCORE=72

# Сколько лучших совпадений показывать (обычно 1)
TOP_K=1

# Если true — бот отвечает только на сообщения с вопросом ("?" или вопросительные слова)
QUESTIONS_ONLY=true

# В группах отвечать только если явно обратились к боту:
# - упомянули @username бота
# - или ответили (reply) на сообщение бота
REQUIRE_TRIGGER=true

# Антиспам
# Минимальная пауза между ответами в одном чате
COOLDOWN_SECONDS=20
# Максимум ответов бота в одном чате за минуту
MAX_REPLIES_PER_MINUTE=6
# Не отправлять одну и ту же ссылку повторно в этом чате в течение N секунд
DUPLICATE_WINDOW_SECONDS=1800

# Постепенная индексация (чтобы не грузить сайт и чтобы продолжать после перезапуска)
# Сколько страниц докачивать за один шаг
INDEX_BATCH_SIZE=10
# Раз в сколько секунд делать следующий шаг
INDEX_INTERVAL_SECONDS=15
# Автоподстройка интервала индексации (уменьшает WARN про skipped)
AUTO_TUNE_INDEXER=true
# Минимальный/максимальный интервал (сек)
INDEX_INTERVAL_MIN_SECONDS=5
INDEX_INTERVAL_MAX_SECONDS=120

# Диагностика: логировать каждое входящее сообщение (может быть шумно)
LOG_ALL_MESSAGES=false

# Диагностика: логировать решения бота (почему ответил/почему промолчал)
LOG_DECISIONS=true

# Уведомление в чат, когда индексация завершена
NOTIFY_ON_INDEX_DONE=true
NOTIFY_CHAT_ID=
NOTIFY_MENTION=

# В группах в конце ответа бота — @упоминание (уведомление ревьюеру). Пусто или off — выкл.
REPLY_REVIEW_MENTION=rkfsociety

# Русский слой: расширение русских запросов англ. ключевыми словами
RU_LAYER_ENABLED=true

# Уточняющие вопросы (если бот “почти уверен”, но не хватает данных)
CLARIFY_ENABLED=true
# Если лучший score ниже MIN_SCORE, но >= CLARIFY_MIN_SCORE — бот может попросить уточнение
CLARIFY_MIN_SCORE=45
# Не задавать уточняющие вопросы слишком часто (на чат+пользователь), сек
CLARIFY_COOLDOWN_SECONDS=300
# После ответа на уточнение: сколько раз можно ответить reply на бота с другой моделью (0 = выкл.)
CLARIFY_CORRECTION_MAX=2
# Срок «сессии поправок» от последней активности, сек
CLARIFY_CORRECTION_TTL_SECONDS=600

# Разработчики: дополнительные numeric user_id через запятую (к базовому списку в коде, см. app/default_developers.py).
# В группах — те же служебные команды, что у админа чата; без антиспама по чату и без кулдаунов clarify.
# DEVELOPER_USER_IDS=

# Чаты (chat_id через запятую), где не автоудалять пару «команда + ответ бота» после 20 с.
# К дефолтному списку в app/default_ephemeral_exempt.py добавляются перечисленные здесь id.
# EPHEMERAL_EXEMPT_CHAT_IDS=

# Служебный чат: старт бота, ошибки обработчиков, перезапуски (/update, git autopull). Дефолт в app/default_ops_chat.py.
# 0 или off — не слать. Иначе числовой chat_id (можно переопределить дефолт).
# OPS_NOTIFY_CHAT_ID=

# (Опционально) Ограничить работу ботом в конкретных группах/чатах и/или темах:
# ALLOWED_CHAT_IDS=-1001234567890,-1009876543210  # список chat_id через запятую
# ALLOWED_TOPIC_IDS=10,20,30                    # список topic_id (thread_id) через запятую
# Для разрешения только общей темы General используйте 0: ALLOWED_TOPIC_IDS=0
# Если задан только один список — фильтр по нему. Если заданы оба — нужен и чат из ALLOWED_CHAT_IDS, и тема из ALLOWED_TOPIC_IDS.

# Перед поиском по вики: getChatMember; если боту нельзя писать в чат/тему — сообщение не обрабатывается (0=выкл.).
# REQUIRE_CAN_REPLY=false

# TTL кэша getChatMember при REQUIRE_CAN_REPLY=1 (сек).
# REPLY_ACCESS_CACHE_SECONDS=300
# Команда /status работает везде, но покажет статус доступа для текущего чата/темы.

# --- Веб-панель администратора (запускается вместе с ботом, тот же процесс) ---
# Включить панель (для входа через бота задайте явно true):
# PANEL_ENABLED=true
PANEL_HOST=0.0.0.0
PANEL_PORT=8080
# Вход 1 — через Telegram-бота, БЕЗ домена (рекомендуется): кнопка на странице входа
# открывает t.me/<бот>?start=код, вы жмёте Start; доступ только админам группы
# PANEL_ADMIN_CHAT_ID. Включён по умолчанию (PANEL_TG_LOGIN=true).
# PANEL_TG_LOGIN=true
# Группа, чьи админы могут входить (по умолчанию основная). 0/off — выключить вход через TG.
# PANEL_ADMIN_CHAT_ID=-1003881305021
# Вход 2 — запасной по логину/паролю (членство в группе НЕ проверяет). Пустой пароль = выкл.
PANEL_USERNAME=admin
PANEL_PASSWORD=
# Срок жизни сессии входа, секунд (по умолчанию сутки)
# PANEL_SESSION_TTL_SECONDS=86400
