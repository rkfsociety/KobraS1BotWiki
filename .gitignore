```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Dependencies
node_modules/

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
target/
*.out
*.exe
*.dll
*.so
*.a

# Testing
.pytest_cache/
.mypy_cache/
```